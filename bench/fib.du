// Fibonacci iterative - 10000 iterations
function fib_iter(n)
  if n <= 1 then
    return n
  end
  a = 0
  b = 1
  for i = 2, n do
    temp = a + b
    a = b
    b = temp
  end
  return b
end

start = timer()
for i = 1, 10000 do
  result = fib_iter(30)
end
elapsed = (timer() - start) * 1000

print("fib(30) iterative x10000 = " + result + " in " + elapsed + "ms")
